{
  "manifest_version": 3,
  "name": "switch-dress",
  "version": "0.1.0",
  "description": "Chrome Extension base infrastructure with React + TypeScript + Vite",
  "permissions": ["storage", "activeTab"],
  "optional_permissions": ["tabs", "scripting"],
  "host_permissions": [],
  "action": {
    "default_title": "switch-dress",
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.tsx"]
    }
  ],
  "options_page": "options/index.html"
}
